@page "{id:int}"
@model appWebEnvio.Pages.Clientes.DeleteModel
@{
    Layout = "_Layout";
}

<h1>Eliminar Cliente</h1>

<div>
    <h4>Cliente</h4>
    <hr />
    <dl class="row">
        <dt class="col-sm-2">Nombre</dt>
        <dd class="col-sm-10">@Model.Cliente.Nombre</dd>

        <dt class="col-sm-2">Telefono</dt>
        <dd class="col-sm-10">@Model.Cliente.Telefono</dd>

        <dt class="col-sm-2">Email</dt>
        <dd class="col-sm-10">@Model.Cliente.Email</dd>

        <dt class="col-sm-2">Direccion</dt>
        <dd class="col-sm-10">@Model.Cliente.Direccion</dd>
    </dl>
</div>

<form method="post">
    <input type="hidden" asp-for="Cliente.ClienteId" />
    <button type="submit" class="btn btn-danger">Eliminar</button>
    <a asp-page="Index" class="btn btn-secondary">Cancelar</a>
</form>