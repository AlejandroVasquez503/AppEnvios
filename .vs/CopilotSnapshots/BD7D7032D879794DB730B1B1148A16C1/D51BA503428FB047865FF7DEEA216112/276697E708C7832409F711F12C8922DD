@page "{id:int}"
@model appWebEnvio.Pages.Clientes.DeleteModel
@{
    Layout = "_Layout";
}

<style>
    .delete-container {
        max-width: 500px;
        margin: 3rem auto;
    }
    .delete-title {
        font-weight: 700;
        color: #8b3333;
        margin-bottom: 1.5rem;
        font-size: 1.8rem;
        letter-spacing: -0.5px;
    }
    .warning-box {
        background-color: #fff3cd;
        border-left: 4px solid #ff9800;
        padding: 1.2rem;
        border-radius: 2px;
        margin-bottom: 2rem;
    }
    .warning-box p {
        margin: 0;
        color: #856404;
        font-weight: 500;
    }
    .client-preview {
        background-color: #f8f9fa;
        padding: 1.5rem;
        border-radius: 4px;
        margin-bottom: 2rem;
        border: 1px solid #ecf0f1;
    }
    .preview-item {
        display: flex;
        justify-content: space-between;
        padding: 0.8rem 0;
        border-bottom: 1px solid #ecf0f1;
    }
    .preview-item:last-child {
        border-bottom: none;
    }
    .preview-label {
        font-weight: 600;
        color: #7f8c8d;
        font-size: 0.9rem;
    }
    .preview-value {
        color: #2c3e50;
        font-weight: 500;
    }
    .delete-actions {
        display: flex;
        gap: 1rem;
    }
    .btn-danger {
        background-color: #c33;
        color: white;
        padding: 0.8rem 2rem;
        border: none;
        border-radius: 4px;
        font-weight: 600;
        cursor: pointer;
        transition: background-color 0.2s;
    }
    .btn-danger:hover {
        background-color: #a00;
    }
    .btn-cancel {
        background-color: transparent;
        color: #2c3e50;
        padding: 0.8rem 2rem;
        border: 1px solid #ddd;
        border-radius: 4px;
        font-weight: 600;
        cursor: pointer;
        text-decoration: none;
        transition: border-color 0.2s;
    }
    .btn-cancel:hover {
        border-color: #2c3e50;
    }
</style>

<div class="delete-container">
    <h1 class="delete-title">Eliminar Cliente</h1>

    <div class="warning-box">
        <p>⚠️ Esta acción no se puede deshacer. Verifica que sea el cliente correcto.</p>
    </div>

    <div class="client-preview">
        <div class="preview-item">
            <span class="preview-label">Nombre</span>
            <span class="preview-value">@Model.Cliente.Nombre</span>
        </div>
        <div class="preview-item">
            <span class="preview-label">Teléfono</span>
            <span class="preview-value">@Model.Cliente.Telefono</span>
        </div>
        <div class="preview-item">
            <span class="preview-label">Email</span>
            <span class="preview-value">@Model.Cliente.Email</span>
        </div>
        <div class="preview-item">
            <span class="preview-label">Dirección</span>
            <span class="preview-value">@Model.Cliente.Direccion</span>
        </div>
    </div>

    <p style="color: #7f8c8d; margin-bottom: 1.5rem;">¿Deseas continuar con la eliminación?</p>

    <form method="post" style="display: contents;">
        <input type="hidden" asp-for="Cliente.ClienteId" />
        <div class="delete-actions">
            <button type="submit" class="btn-danger">Sí, Eliminar</button>
            <a asp-page="Index" class="btn-cancel">Cancelar</a>
        </div>
    </form>
</div>