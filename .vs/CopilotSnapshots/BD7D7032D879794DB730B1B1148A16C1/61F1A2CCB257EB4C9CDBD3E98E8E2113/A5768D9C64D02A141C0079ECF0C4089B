@page "{id:int}"
@model appWebEnvio.Pages.Clientes.DetailsModel
@{
    Layout = "_Layout";
}

<div class="container mt-5">
    <div class="row justify-content-center">
        <div class="col-md-6">
            <h1 class="mb-4">Detalles del Cliente</h1>

            <div class="border p-4 rounded">
                <div class="mb-3 pb-3 border-bottom">
                    <label class="form-label text-muted">Nombre</label>
                    <p>@Model.Cliente.Nombre</p>
                </div>

                <div class="mb-3 pb-3 border-bottom">
                    <label class="form-label text-muted">Teléfono</label>
                    <p>@Model.Cliente.Telefono</p>
                </div>

                <div class="mb-3 pb-3 border-bottom">
                    <label class="form-label text-muted">Email</label>
                    <p>@Model.Cliente.Email</p>
                </div>

                <div class="mb-4">
                    <label class="form-label text-muted">Dirección</label>
                    <p>@Model.Cliente.Direccion</p>
                </div>

                <div class="d-flex gap-2">
                    <a asp-page="Edit" asp-route-id="@Model.Cliente.ClienteId" class="btn btn-primary">Editar</a>
                    <a asp-page="Index" class="btn btn-outline-secondary">Volver</a>
                </div>
            </div>
        </div>
    </div>
</div>