@page
@model appWebEnvio.Pages.Clientes.IndexModel
@{
    Layout = "_Layout";
}

<style>
    .header-section {
        border-bottom: 3px solid #2c3e50;
        padding-bottom: 1.5rem;
        margin-bottom: 2rem;
    }
    .header-section h1 {
        font-weight: 700;
        letter-spacing: -0.5px;
        margin: 0;
    }
    .client-table {
        background: #fff;
    }
    .client-table tbody tr {
        border-bottom: 1px solid #ecf0f1;
        transition: background-color 0.2s;
    }
    .client-table tbody tr:hover {
        background-color: #f8f9fa;
    }
    .action-cell {
        display: flex;
        gap: 0.4rem;
    }
    .btn-action {
        padding: 0.35rem 0.8rem;
        font-size: 0.875rem;
        border-radius: 4px;
        text-decoration: none;
    }
    .empty-state {
        text-align: center;
        padding: 3rem 1rem;
        color: #7f8c8d;
    }
    .empty-state p {
        font-size: 1.1rem;
        margin: 0;
    }
</style>

<div class="container" style="max-width: 1000px; padding-top: 2rem; padding-bottom: 3rem;">
    <div class="header-section d-flex justify-content-between align-items-flex-start">
        <div>
            <h1>Usuarios</h1>
        </div>
        <a class="btn" asp-page="Create" style="background-color: #2c3e50; color: white; padding: 0.6rem 1.5rem; border-radius: 4px; text-decoration: none; font-weight: 600; border: none; cursor: pointer;">+ Agregar Usuario</a>
    </div>

    @if (Model.ClientesList.Count == 0)
    {
    }
    else
    {
        <div style="border-radius: 6px; overflow: hidden; border: 1px solid #ecf0f1;">
            <table class="table table-sm client-table" style="margin: 0;">
                <thead style="background-color: #f8f9fa; border-bottom: 2px solid #2c3e50;">
                    <tr>
                        <th style="padding: 1rem; font-weight: 600; color: #2c3e50;">Nombre</th>
                        <th style="padding: 1rem; font-weight: 600; color: #2c3e50;">Teléfono</th>
                        <th style="padding: 1rem; font-weight: 600; color: #2c3e50;">Email</th>
                        <th style="padding: 1rem; font-weight: 600; color: #2c3e50;">Dirección</th>
                        <th style="padding: 1rem; font-weight: 600; color: #2c3e50; text-align: right;">Acciones</th>
                    </tr>
                </thead>
                <tbody>
                    @foreach (var item in Model.ClientesList)
                    {
                        <tr>
                            <td style="padding: 1rem; font-weight: 500;">@item.Nombre</td>
                            <td style="padding: 1rem; color: #555;">@item.Telefono</td>
                            <td style="padding: 1rem; color: #555;">@item.Email</td>
                            <td style="padding: 1rem; color: #555;">@item.Direccion</td>
                            <td style="padding: 1rem; text-align: right;">
                                <div class="action-cell" style="justify-content: flex-end;">
                                    <a class="btn-action" asp-page="Details" asp-route-id="@item.ClienteId" style="background-color: #e8f4f8; color: #2c3e50; border: 1px solid #d0e8f2;">Ver</a>
                                    <a class="btn-action" asp-page="Edit" asp-route-id="@item.ClienteId" style="background-color: #fef3e8; color: #8b5a00; border: 1px solid #f0d9b5;">Editar</a>
                                    <a class="btn-action" asp-page="Delete" asp-route-id="@item.ClienteId" style="background-color: #ffe8e8; color: #8b3333; border: 1px solid #f0d0d0;">Eliminar</a>
                                </div>
                            </td>
                        </tr>
                    }
                </tbody>
            </table>
        </div>
    }
</div>