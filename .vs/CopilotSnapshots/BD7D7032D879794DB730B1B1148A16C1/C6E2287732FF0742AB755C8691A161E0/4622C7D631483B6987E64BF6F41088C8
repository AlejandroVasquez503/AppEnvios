@page
@model appWebEnvio.Pages.Clientes.IndexModel
@{
    Layout = "_Layout";
}

<div class="container py-5">
    <div class="d-flex justify-content-between align-items-center mb-4">
        <div>
            <h1 class="h2 fw-bold text-dark">Gestión de Clientes</h1>
            <p class="text-muted">Administra todos tus clientes</p>
        </div>
        <a class="btn btn-success btn-lg" asp-page="Create">
            <i class="bi bi-plus-circle"></i> Nuevo Cliente
        </a>
    </div>

    @if (Model.ClientesList.Count == 0)
    {
        <div class="alert alert-info text-center py-5" role="alert">
            <h5 class="mb-2">No hay clientes registrados</h5>
            <p class="mb-0">Comienza creando tu primer cliente</p>
        </div>
    }
    else
    {
        <div class="table-responsive shadow-sm rounded">
            <table class="table table-hover mb-0">
                <thead class="table-light">
                    <tr>
                        <th scope="col" class="fw-bold">Nombre</th>
                        <th scope="col" class="fw-bold">Teléfono</th>
                        <th scope="col" class="fw-bold">Email</th>
                        <th scope="col" class="fw-bold">Dirección</th>
                        <th scope="col" class="fw-bold text-center">Acciones</th>
                    </tr>
                </thead>
                <tbody>
                    @foreach (var item in Model.ClientesList)
                    {
                        <tr>
                            <td class="fw-500">@item.Nombre</td>
                            <td>@item.Telefono</td>
                            <td><a href="mailto:@item.Email" class="text-decoration-none">@item.Email</a></td>
                            <td>@item.Direccion</td>
                            <td class="text-center">
                                <a class="btn btn-sm btn-info" asp-page="Details" asp-route-id="@item.ClienteId" title="Ver detalles">
                                    <i class="bi bi-eye"></i> Ver
                                </a>
                                <a class="btn btn-sm btn-warning" asp-page="Edit" asp-route-id="@item.ClienteId" title="Editar">
                                    <i class="bi bi-pencil"></i> Editar
                                </a>
                                <a class="btn btn-sm btn-danger" asp-page="Delete" asp-route-id="@item.ClienteId" title="Eliminar">
                                    <i class="bi bi-trash"></i> Eliminar
                                </a>
                            </td>
                        </tr>
                    }
                </tbody>
            </table>
        </div>
    }
</div>