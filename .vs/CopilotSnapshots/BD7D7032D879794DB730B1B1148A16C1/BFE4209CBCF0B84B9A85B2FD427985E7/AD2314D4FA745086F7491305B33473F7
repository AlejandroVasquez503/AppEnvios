@page "{id:int}"
@model appWebEnvio.Pages.Clientes.DetailsModel
@{
    Layout = "_Layout";
}

<div class="container py-5">
    <div class="row justify-content-center">
        <div class="col-lg-6">
            <div class="card shadow-lg border-0">
                <div class="card-header bg-info text-white py-4">
                    <h2 class="card-title mb-0">
                        <i class="bi bi-person-circle"></i> Detalles del Cliente
                    </h2>
                </div>
                <div class="card-body p-4">
                    <div class="row mb-3 pb-3 border-bottom">
                        <div class="col-sm-4">
                            <h6 class="text-muted fw-bold">
                                <i class="bi bi-person"></i> Nombre
                            </h6>
                        </div>
                        <div class="col-sm-8">
                            <p class="mb-0 fs-5">@Model.Cliente.Nombre</p>
                        </div>
                    </div>

                    <div class="row mb-3 pb-3 border-bottom">
                        <div class="col-sm-4">
                            <h6 class="text-muted fw-bold">
                                <i class="bi bi-telephone"></i> Teléfono
                            </h6>
                        </div>
                        <div class="col-sm-8">
                            <p class="mb-0 fs-5">
                                <a href="tel:@Model.Cliente.Telefono" class="text-decoration-none">@Model.Cliente.Telefono</a>
                            </p>
                        </div>
                    </div>

                    <div class="row mb-3 pb-3 border-bottom">
                        <div class="col-sm-4">
                            <h6 class="text-muted fw-bold">
                                <i class="bi bi-envelope"></i> Email
                            </h6>
                        </div>
                        <div class="col-sm-8">
                            <p class="mb-0 fs-5">
                                <a href="mailto:@Model.Cliente.Email" class="text-decoration-none">@Model.Cliente.Email</a>
                            </p>
                        </div>
                    </div>

                    <div class="row mb-4">
                        <div class="col-sm-4">
                            <h6 class="text-muted fw-bold">
                                <i class="bi bi-geo-alt"></i> Dirección
                            </h6>
                        </div>
                        <div class="col-sm-8">
                            <p class="mb-0 fs-5">@Model.Cliente.Direccion</p>
                        </div>
                    </div>

                    <div class="d-grid gap-2 d-sm-flex justify-content-sm-end">
                        <a asp-page="Edit" asp-route-id="@Model.Cliente.ClienteId" class="btn btn-warning btn-lg">
                            <i class="bi bi-pencil"></i> Editar
                        </a>
                        <a asp-page="Index" class="btn btn-outline-secondary btn-lg">
                            <i class="bi bi-arrow-left"></i> Volver
                        </a>
                    </div>
                </div>
            </div>
        </div>
    </div>
</div>