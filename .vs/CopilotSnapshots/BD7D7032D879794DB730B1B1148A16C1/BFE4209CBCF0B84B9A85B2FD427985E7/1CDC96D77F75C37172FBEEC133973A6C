@page "{id:int}"
@model appWebEnvio.Pages.Clientes.DeleteModel
@{
    Layout = "_Layout";
}

<div class="container py-5">
    <div class="row justify-content-center">
        <div class="col-lg-6">
            <div class="card shadow-lg border-0 border-danger">
                <div class="card-header bg-danger text-white py-4">
                    <h2 class="card-title mb-0">
                        <i class="bi bi-exclamation-circle"></i> Confirmar Eliminación
                    </h2>
                </div>
                <div class="card-body p-4">
                    <div class="alert alert-warning" role="alert">
                        <i class="bi bi-exclamation-triangle-fill"></i>
                        <strong>¡Advertencia!</strong> Esta acción no se puede deshacer.
                    </div>

                    <p class="mb-4 text-muted">¿Está seguro de que desea eliminar al cliente?</p>

                    <div class="card bg-light p-3 mb-4">
                        <div class="row mb-2 pb-2 border-bottom">
                            <div class="col-4">
                                <h6 class="text-muted fw-bold">
                                    <i class="bi bi-person"></i> Nombre
                                </h6>
                            </div>
                            <div class="col-8">
                                <p class="mb-0">@Model.Cliente.Nombre</p>
                            </div>
                        </div>

                        <div class="row mb-2 pb-2 border-bottom">
                            <div class="col-4">
                                <h6 class="text-muted fw-bold">
                                    <i class="bi bi-telephone"></i> Teléfono
                                </h6>
                            </div>
                            <div class="col-8">
                                <p class="mb-0">@Model.Cliente.Telefono</p>
                            </div>
                        </div>

                        <div class="row mb-2 pb-2 border-bottom">
                            <div class="col-4">
                                <h6 class="text-muted fw-bold">
                                    <i class="bi bi-envelope"></i> Email
                                </h6>
                            </div>
                            <div class="col-8">
                                <p class="mb-0">@Model.Cliente.Email</p>
                            </div>
                        </div>

                        <div class="row">
                            <div class="col-4">
                                <h6 class="text-muted fw-bold">
                                    <i class="bi bi-geo-alt"></i> Dirección
                                </h6>
                            </div>
                            <div class="col-8">
                                <p class="mb-0">@Model.Cliente.Direccion</p>
                            </div>
                        </div>
                    </div>

                    <form method="post">
                        <input type="hidden" asp-for="Cliente.ClienteId" />
                        <div class="d-grid gap-2 d-sm-flex justify-content-sm-end">
                            <button type="submit" class="btn btn-danger btn-lg">
                                <i class="bi bi-trash"></i> Sí, Eliminar
                            </button>
                            <a asp-page="Index" class="btn btn-outline-secondary btn-lg">
                                <i class="bi bi-x-circle"></i> Cancelar
                            </a>
                        </div>
                    </form>
                </div>
            </div>
        </div>
    </div>
</div>