@page "{id:int}"
@model appWebEnvio.Pages.Clientes.DeleteModel
@{
    Layout = "_Layout";
}

<div class="container mt-5">
    <div class="row justify-content-center">
        <div class="col-md-6">
            <h1 class="mb-4">Eliminar Cliente</h1>

            <div class="alert alert-warning mb-4">
                <strong>Advertencia:</strong> Esta acción no se puede deshacer.
            </div>

            <div class="border p-4 rounded bg-light mb-4">
                <div class="mb-3 pb-3 border-bottom">
                    <label class="form-label text-muted">Nombre</label>
                    <p>@Model.Cliente.Nombre</p>
                </div>

                <div class="mb-3 pb-3 border-bottom">
                    <label class="form-label text-muted">Teléfono</label>
                    <p>@Model.Cliente.Telefono</p>
                </div>

                <div class="mb-3 pb-3 border-bottom">
                    <label class="form-label text-muted">Email</label>
                    <p>@Model.Cliente.Email</p>
                </div>

                <div class="mb-3">
                    <label class="form-label text-muted">Dirección</label>
                    <p>@Model.Cliente.Direccion</p>
                </div>
            </div>

            <p class="mb-4">¿Desea continuar con la eliminación de este cliente?</p>

            <form method="post">
                <input type="hidden" asp-for="Cliente.ClienteId" />
                <div class="d-flex gap-2">
                    <button type="submit" class="btn btn-danger">Sí, Eliminar</button>
                    <a asp-page="Index" class="btn btn-outline-secondary">Cancelar</a>
                </div>
            </form>
        </div>
    </div>
</div>