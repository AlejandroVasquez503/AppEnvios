@page "{id:int}"
@model appWebEnvio.Pages.Clientes.EditModel
@{
    Layout = "_Layout";
}

<div class="container py-5">
    <div class="row justify-content-center">
        <div class="col-lg-6">
            <div class="card shadow-lg border-0">
                <div class="card-header bg-warning text-dark py-4">
                    <h2 class="card-title mb-0">
                        <i class="bi bi-pencil-square"></i> Editar Cliente
                    </h2>
                </div>
                <div class="card-body p-4">
                    @if (!ViewData.ModelState.IsValid)
                    {
                        <div class="alert alert-danger alert-dismissible fade show" role="alert">
                            <h5 class="alert-heading">
                                <i class="bi bi-exclamation-triangle"></i> Errores de validación
                            </h5>
                            <ul class="mb-0">
                                @foreach (var modelState in ViewData.ModelState.Values)
                                {
                                    @foreach (var error in modelState.Errors)
                                    {
                                        <li>@error.ErrorMessage</li>
                                    }
                                }
                            </ul>
                            <button type="button" class="btn-close" data-bs-dismiss="alert" aria-label="Close"></button>
                        </div>
                    }
                    <form method="post" novalidate>
                        <input type="hidden" asp-for="Cliente.ClienteId" />

                        <div class="mb-3">
                            <label asp-for="Cliente.Nombre" class="form-label fw-bold">
                                <i class="bi bi-person"></i> Nombre
                            </label>
                            <input asp-for="Cliente.Nombre" class="form-control form-control-lg" />
                            <span asp-validation-for="Cliente.Nombre" class="text-danger small"></span>
                        </div>

                        <div class="mb-3">
                            <label asp-for="Cliente.Telefono" class="form-label fw-bold">
                                <i class="bi bi-telephone"></i> Teléfono
                            </label>
                            <input asp-for="Cliente.Telefono" class="form-control form-control-lg" />
                            <span asp-validation-for="Cliente.Telefono" class="text-danger small"></span>
                        </div>

                        <div class="mb-3">
                            <label asp-for="Cliente.Email" class="form-label fw-bold">
                                <i class="bi bi-envelope"></i> Email
                            </label>
                            <input asp-for="Cliente.Email" class="form-control form-control-lg" type="email" />
                            <span asp-validation-for="Cliente.Email" class="text-danger small"></span>
                        </div>

                        <div class="mb-4">
                            <label asp-for="Cliente.Direccion" class="form-label fw-bold">
                                <i class="bi bi-geo-alt"></i> Dirección
                            </label>
                            <input asp-for="Cliente.Direccion" class="form-control form-control-lg" />
                            <span asp-validation-for="Cliente.Direccion" class="text-danger small"></span>
                        </div>

                        <div class="d-grid gap-2 d-sm-flex justify-content-sm-end">
                            <button type="submit" class="btn btn-warning btn-lg">
                                <i class="bi bi-check-circle"></i> Guardar Cambios
                            </button>
                            <a asp-page="Index" class="btn btn-outline-secondary btn-lg">
                                <i class="bi bi-x-circle"></i> Cancelar
                            </a>
                        </div>
                    </form>
                </div>
            </div>
        </div>
    </div>
</div>

@section Scripts {
    <partial name="_ValidationScriptsPartial" />
}