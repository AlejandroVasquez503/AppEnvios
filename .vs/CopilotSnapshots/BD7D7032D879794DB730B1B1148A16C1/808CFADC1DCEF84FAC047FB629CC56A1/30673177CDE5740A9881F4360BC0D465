@page
@model appWebEnvio.Pages.Clientes.IndexModel
@{
    Layout = "_Layout";
}

<h1>Clientes</h1>

<p>
    <a class="btn btn-primary" asp-page="Create">Crear Nuevo Cliente</a>
</p>

<table class="table table-striped">
    <thead>
        <tr>
            <th>Nombre</th>
            <th>Telefono</th>
            <th>Email</th>
            <th>Direccion</th>
            <th></th>
        </tr>
    </thead>
    <tbody>
@foreach (var item in Model.ClientesList)
{
        <tr>
            <td>@item.Nombre</td>
            <td>@item.Telefono</td>
            <td>@item.Email</td>
            <td>@item.Direccion</td>
            <td>
                <a class="btn btn-sm btn-info" asp-page="Details" asp-route-id="@item.ClienteId">Detalles</a>
                <a class="btn btn-sm btn-warning" asp-page="Edit" asp-route-id="@item.ClienteId">Editar</a>
                <a class="btn btn-sm btn-danger" asp-page="Delete" asp-route-id="@item.ClienteId">Eliminar</a>
            </td>
        </tr>
}
    </tbody>
</table>